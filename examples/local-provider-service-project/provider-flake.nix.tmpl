{
  description = "Hostenv local provider-service project demo provider";

  inputs = {
    hostenv.url = "__HOSTENV_SOURCE_DIR__";
    nixpkgs.follows = "hostenv/nixpkgs";
    flake-parts.follows = "hostenv/flake-parts";
    sops-nix.follows = "hostenv/sops-nix";
    phps.follows = "hostenv/phps";

    demo__app = {
      url = "__APP_PROJECT_URL__";
      inputs.nixpkgs.follows = "nixpkgs";
      inputs.hostenv.follows = "hostenv";
      inputs.flake-parts.follows = "flake-parts";
    };

    # Keep the underscore alias visible for later test assertions, while the
    # hyphenated project input remains the evaluated Hostenv project name that
    # matches provider-service-project/.hostenv/hostenv.nix.
    demo__provider_service = {
      url = "__PROVIDER_SERVICE_PROJECT_URL__";
      flake = false;
    };

    "demo__provider-service" = {
      url = "__PROVIDER_SERVICE_PROJECT_URL__";
      inputs.nixpkgs.follows = "nixpkgs";
      inputs.hostenv.follows = "hostenv";
      inputs.flake-parts.follows = "flake-parts";
    };

    drupal-main-2855093.follows = "demo__app";
  };

  outputs = inputs@{ flake-parts, hostenv, ... }:
    flake-parts.lib.mkFlake { inherit inputs; } {
      systems = [ "x86_64-linux" ];
      imports = [ hostenv.flakeModules.provider ];

      flake =
        let
          generatedDeployOutputs =
            if builtins.pathExists ./generated/plan.json then
              hostenv.lib.provider.deployOutputs {
                config = builtins.removeAttrs (builtins.fromJSON (builtins.readFile ./generated/plan.json)) [ "_description" ];
                nixpkgs = inputs.nixpkgs;
                inherit inputs;
                localSystem = "x86_64-linux";
                nodesPath = ./nodes;
                secretsPath = ./generated/secrets.merged.yaml;
                nodeSystems = { default = "x86_64-linux"; node-a = "x86_64-linux"; node-b = "x86_64-linux"; };
                nodeModules = [ ];
              }
            else
              { };
        in
        {
          nixosConfigurations = generatedDeployOutputs.nixosConfigurations or { };
        };

      provider = {
        hostenvHostname = "__HOSTENV_HOSTNAME__";
        nixSigning.trustedPublicKeys = [ "__NIX_SIGNING_PUBLIC_KEY__" ];
        nodeSystems = { default = "x86_64-linux"; node-a = "x86_64-linux"; node-b = "x86_64-linux"; };
        nodeFor = {
          default = "node-a";
          production = "__PRODUCTION_NODE__";
          testing = "node-a";
          development = "node-a";
        };
        service = {
          organisation = "demo";
          project = "provider-service";
          environmentName = "provider-service";
        };
        deploy = {
          enable = true;
          reconnectSeconds = 5;
        };
        planSource = "eval";
        letsEncrypt = { adminEmail = "demo@example.test"; acceptTerms = true; };
      };
    };
}
